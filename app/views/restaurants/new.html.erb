<h1>Create a new restaurant</h1>
<%= simple_form_for(@restaurant) do |f| %>
  <%= f.input :name %>
  <%= f.input :address %>
  <%= f.select :category, [ "chinese", "italian", "japanese", "french", "belgian"], {include_blank: "Select a category" } %>
  <%= f.input :phone_number %>
  <%= f.submit "Create a new restaurant", class: "btn btn-primary" %>
<% end %>
